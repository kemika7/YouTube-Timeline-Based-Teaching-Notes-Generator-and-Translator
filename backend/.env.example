# Required: API key for whichever provider you use.
OPENAI_API_KEY=sk-your-key-here

# Optional: override the OpenAI base URL to use any OpenAI-compatible API
# - Leave empty for OpenAI:                (no value)
# - Ollama Cloud:                          https://ollama.com/v1
# - Local Ollama:                          http://localhost:11434/v1
# - Groq:                                  https://api.groq.com/openai/v1
OPENAI_BASE_URL=

# Model name for that provider.
#   OpenAI:        gpt-4o-mini
#   Ollama Cloud:  gpt-oss:20b  (or gpt-oss:120b)
#   Ollama local:  llama3.1     (any model you have pulled)
#   Groq:          llama-3.1-70b-versatile
OPENAI_MODEL=gpt-4o-mini

CACHE_DIR=.cache
HISTORY_FILE=.cache/history.json
PORT=8000
